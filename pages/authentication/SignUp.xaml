<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              x:Class="LeafBucket.pages.authentication.SignUp"
             Title="SignUp">
     <VerticalStackLayout
        VerticalOptions="Center"
        Padding="30,0"
        >

        <Label 
            Text="Create your account "
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

               <Entry x:Name="FirstName"
                 Placeholder="First Name"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                />
                <Label x:Name="FirstNameErrorLabel"
                   TextColor="Red"
                   IsVisible="False"
                   VerticalOptions="Center" 
                   HorizontalOptions="Start" />

                <Entry
                     x:Name="LastName"
                     Placeholder="Last Name"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                />
                    <Label x:Name="LastNameErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

            <Entry
                 x:Name="Email"
                 Placeholder="Email"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                />
                    <Label x:Name="EmailErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

            <Entry
                 x:Name="PhoneNumber"
                 Placeholder="Phone Number"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                Keyboard="Telephone"
                />

                    <Label x:Name="PhoneNumberErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

            <Entry
                 x:Name="Address"
                 Placeholder="Address"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                />

                    <Label x:Name="AddressErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

            <Entry
                 x:Name="Password"
                 Placeholder="Password"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                />
                    <Label x:Name="PasswordErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

                <Entry x:Name="ConfirmPassword"
                 Placeholder="Confirm Password"
                VerticalOptions="Center" 
                Margin="0,20,0,20"
                />
                    <Label x:Name="ConfirmPasswordErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />


                <Label Text="I am a: "
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

           <Grid ColumnDefinitions="Auto,Auto,*,Auto"
      ColumnSpacing="6"
      VerticalOptions="Center"
      Margin="0,10,0,20">

    <CheckBox x:Name="CustomerCheckBox"
              IsChecked="False"
              VerticalOptions="Center" />

    <Label Grid.Column="1"
           Text="Customer"
           VerticalOptions="Center" />

    <CheckBox x:Name="FarmerCheckBox"
              Grid.Column="2"
              IsChecked="False"
              VerticalOptions="Center" />

    <Label Grid.Column="3"
           Text="Farmer"
           VerticalOptions="Center" /> 

</Grid>
 
 <Label x:Name="RoleErrorLabel"
                    TextColor="Red"
                    IsVisible="False"
                    VerticalOptions="Center" 
                    HorizontalOptions="Start" />

            <Button Text="SignUp"
                VerticalOptions="Center"
                Padding="20"
                Margin="0,0,0,20"
                Clicked="SignUpButton_Clicked"
                />

            <Grid ColumnDefinitions="Auto,Auto"
      ColumnSpacing="6"
      VerticalOptions="Center"
      HorizontalOptions="Center"
      Margin="0,10,0,20">

            <Label Grid.Column="0"
                 Text="Already have an account?"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <Label Grid.Column="1"
                 Text="Login now"
                TextColor="#ACF117"
                VerticalOptions="Center"
                HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LoginNavigation" />
                </Label.GestureRecognizers>
            </Label>

        </Grid>



    </VerticalStackLayout>
</ContentPage>