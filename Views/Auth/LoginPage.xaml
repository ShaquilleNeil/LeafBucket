<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Auth.LoginPage"
             Title=""
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             WidthRequest="400"
                             Padding="30"
                             Spacing="8">

            <Label Text="🌿" FontSize="48"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>

            <Label Text="LEAF BUCKET" FontSize="28"
                   FontAttributes="Bold" TextColor="#2E7D32"
                   HorizontalOptions="Center"/>

            <Label Text="Fresh from the Farm"
                   FontSize="14" TextColor="#888"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24"/>

            <Label Text="EMAIL" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5"/>
            <Frame Padding="12,8" CornerRadius="8"
                   HasShadow="False" BackgroundColor="White"
                   BorderColor="#E0E0E0">
                <Entry x:Name="Email" Placeholder="placeholder@email.com" TextColor="Black"
                       BackgroundColor="Transparent"/>
            </Frame>
            <Label x:Name="EmailErrorLabel" TextColor="Red"
                   IsVisible="False"/>

            <Label Text="PASSWORD" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="12,8" CornerRadius="8"
                   HasShadow="False" BackgroundColor="White"
                   BorderColor="#E0E0E0">
                <Entry x:Name="Password" Placeholder="••••••••"
                       IsPassword="True"
                       TextColor="Black"
                       BackgroundColor="Transparent"/>
            </Frame>
            <Label x:Name="PasswordErrorLabel" TextColor="Red"
                   IsVisible="False"/>

            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                  ColumnSpacing="6" Margin="0,8,0,0">
               
                <Label Grid.Column="3" Text="Forgot password?"
                       TextColor="#2E7D32" FontSize="13"
                       VerticalOptions="Center" HorizontalOptions="End">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ForgotPasswordNavigation"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <Button Text="SIGN IN"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="15"
                    FontAttributes="Bold"
                    Padding="0,16"
                    Margin="0,16,0,0"
                    Clicked="LoginButton_Clicked"/>

            <Grid ColumnDefinitions="Auto,Auto"
                  ColumnSpacing="6"
                  HorizontalOptions="Center"
                  Margin="0,12,0,0">
                <Label Grid.Column="0" Text="Don't have an account?"
                       FontSize="13" TextColor="#666"
                       VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="Create one now"
                       TextColor="#2E7D32" FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="CreateAccountNavigation"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>