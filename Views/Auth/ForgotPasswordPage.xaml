<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Auth.ForgotPasswordPage"
             Title=""
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <VerticalStackLayout HorizontalOptions="Center"
                             WidthRequest="400"
                             Padding="30"
                             Spacing="12">

            <Label Text="🔑" FontSize="48"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"/>

            <Label Text="FORGOT PASSWORD"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center"/>

            <Label Text="Enter your email address and we'll send you a link to reset your password."
                   FontSize="14" TextColor="#888"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,16"/>

            <Label Text="EMAIL" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5"/>
            <Frame Padding="12,8" CornerRadius="8"
                   HasShadow="False" BackgroundColor="White"
                   BorderColor="#E0E0E0">
                <Entry x:Name="emailEntry"
                       Placeholder="Enter your email"
                       BackgroundColor="Transparent"
                       TextColor="Black"/>
            </Frame>
            <Label x:Name="errorLabel" TextColor="Red"
                   IsVisible="False"/>

            <Button Text="SEND RESET LINK"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="15"
                    FontAttributes="Bold"
                    Padding="0,16"
                    Margin="0,8,0,0"
                    Clicked="OnSendResetClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>