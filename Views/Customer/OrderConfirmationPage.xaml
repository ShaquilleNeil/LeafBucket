<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.OrderConfirmationPage"
             Title=""
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F0">

    <Grid RowDefinitions="*,Auto" Padding="24">

        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="16">

            <Frame WidthRequest="100" HeightRequest="100"
                   CornerRadius="50"
                   BorderColor="#2E7D32"
                   BackgroundColor="#E8F5E9"
                   HasShadow="False"
                   HorizontalOptions="Center"
                   Padding="0">
                <Label Text="✓" FontSize="44"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#2E7D32"/>
            </Frame>

            <Label Text="ORDER PLACED!" FontSize="26"
                   FontAttributes="Bold" TextColor="Black"
                   HorizontalOptions="Center"/>

            <Label x:Name="orderId" FontSize="14"
                   TextColor="#888"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             WidthRequest="400"
                             Spacing="12">

            <Button Text="VIEW ORDER STATUS"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="15"
                    FontAttributes="Bold"
                    Padding="0,16"
                    Clicked="OnViewOrderStatusClicked"/>

            <Label Text="CONTINUE SHOPPING"
                   HorizontalOptions="Center"
                   TextColor="#2E7D32"
                   FontAttributes="Bold"
                   TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnContinueShoppingTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>

    </Grid>
</ContentPage>