<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.ProfilePage"
             Title=""
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <StackLayout Padding="16" Spacing="16">

            <Label Text="LEAF BUCKET" FontSize="22"
                   FontAttributes="Bold" TextColor="#2E7D32"
                   HorizontalOptions="Center"/>

            <Frame WidthRequest="100" HeightRequest="100"
                   CornerRadius="50" Padding="0"
                   HasShadow="True" BorderColor="#C8E6C9"
                   IsClippedToBounds="True"
                   HorizontalOptions="Center">
                <Image x:Name="customerPhoto"
                       Source="https://randomuser.me/api/portraits/men/1.jpg"
                       Aspect="AspectFill"
                       WidthRequest="100"
                       HeightRequest="100"/>
            </Frame>

            <Label x:Name="customerName" Text=""
                   FontSize="20" FontAttributes="Bold"
                   TextColor="#222" HorizontalOptions="Center"/>

            <Label x:Name="customerEmail" Text=""
                   FontSize="13" TextColor="#888"
                   HorizontalOptions="Center" Margin="0,-10,0,0"/>

            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <StackLayout Spacing="12">

                    <StackLayout Spacing="4">
                        <Label Text="ADDRESS" FontSize="11"
                               FontAttributes="Bold" TextColor="#888"
                               CharacterSpacing="1.5"/>
                        <Frame Padding="12,10" CornerRadius="8"
                               HasShadow="False" BackgroundColor="#F5F5F0"
                               BorderColor="#E0E0E0">
                            <Label x:Name="customerAddress"
                                   FontSize="14" TextColor="#333"/>
                        </Frame>
                    </StackLayout>

                    <StackLayout Spacing="4">
                        <Label Text="PHONE" FontSize="11"
                               FontAttributes="Bold" TextColor="#888"
                               CharacterSpacing="1.5"/>
                        <Frame Padding="12,10" CornerRadius="8"
                               HasShadow="False" BackgroundColor="#F5F5F0"
                               BorderColor="#E0E0E0">
                            <Label x:Name="customerPhone"
                                   FontSize="14" TextColor="#333"/>
                        </Frame>
                    </StackLayout>

                </StackLayout>
            </Frame>

            <Label Text="SETTINGS" FontSize="12"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5"/>

            <Frame Padding="0" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <StackLayout Spacing="0">
                    <Grid Padding="16" ColumnDefinitions="*,Auto">
                        <Label Text="Account Settings" FontSize="14" TextColor="#333"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="›" FontSize="20" TextColor="#888"
                               VerticalOptions="Center"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Grid Padding="16" ColumnDefinitions="*,Auto">
                        <Label Text="Notifications" FontSize="14" TextColor="#333"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="›" FontSize="20" TextColor="#888"
                               VerticalOptions="Center"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <Button Text="LOGOUT"
                    BackgroundColor="#C62828"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="Logout_Clicked"/>

        </StackLayout>
    </ScrollView>
</ContentPage>