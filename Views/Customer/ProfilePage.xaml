<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.ProfilePage"
             Title="Profile">
    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center">
        
        
        <Label 
           x:Name="customerName"
           Text=""
            TextColor="Red"
           />

        <Label 
    x:Name="customerAddress"
    Text=""
     TextColor="Red"
    />

        <Label 
    x:Name="customerPhone"
    Text=""
     TextColor="Red"
    />
        
        <Button
            Text="Edit Profile"
          
            Margin="0,0,0,20"
            />
        
         <Button
            Text="Logout"
             BackgroundColor="Red"
            Clicked="Logout_Clicked"
            />


    </VerticalStackLayout>
</ContentPage>
