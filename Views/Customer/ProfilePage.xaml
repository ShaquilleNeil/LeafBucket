<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.ProfilePage"
             Title="Profile">
    <VerticalStackLayout
       
       Padding="20">

        <Frame 
    WidthRequest="200"
    HeightRequest="200"
    CornerRadius="100"
    Padding="0"
    HasShadow="False">

            <Image 
        Source="https://randomuser.me/api/portraits/men/1.jpg"
        Aspect="AspectFill"/>
        </Frame>

        <Label 
           x:Name="customerName"
           Text=""
            HorizontalOptions="Center"
            FontSize="40"
           />


        <Label 
     x:Name="customerEmail"
     Text=""
      TextColor="Gray"
            
      HorizontalOptions="Center"
            Margin="0,0,0,50"
     />


        <Label Text="Address" TextColor="Gray" Margin="0,0,0,10" />

        <VerticalStackLayout
                BackgroundColor="LightGray"
            HeightRequest="80"
           Padding="20"
            Margin="0,0,0,10"
                >

                <Label 
                    x:Name="customerAddress"
                    Text=""
                     TextColor="Red"
                      FontSize="20"
                   
                    />

            </VerticalStackLayout>



        <Label Text="Phone" TextColor="Gray" Margin="0,0,0,10" />

        <VerticalStackLayout
         BackgroundColor="LightGray"
     HeightRequest="80"
    Padding="20"
             Margin="0,0,0,20"
         >

            <Label 
             x:Name="customerPhone"
             Text=""
              TextColor="Red"
                          />


        </VerticalStackLayout>


   
        <Button
            Text="Edit Profile"
          
            Margin="0,0,0,20"
            />
        
         <Button
            Text="Logout"
             BackgroundColor="Red"
            Clicked="Logout_Clicked"
            />


    </VerticalStackLayout>
</ContentPage>
