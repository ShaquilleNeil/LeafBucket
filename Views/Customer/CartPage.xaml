<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.CartPage"
             Title="Cart"
             BackgroundColor="#F5F5F0">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <StackLayout HorizontalOptions="Center"
                         WidthRequest="600"
                         Padding="16" Spacing="12">

                <CollectionView x:Name="CartCollection">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="12" CornerRadius="12"
                                   HasShadow="True" BackgroundColor="White"
                                   Margin="0,4">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12">

                                    <Frame Grid.Column="0"
                                           WidthRequest="70" HeightRequest="70"
                                           CornerRadius="10" Padding="0"
                                           HasShadow="False"
                                           IsClippedToBounds="True">
                                        <Image Source="{Binding imageUrl}"
                                               Aspect="AspectFill"
                                               WidthRequest="70"
                                               HeightRequest="70"/>
                                    </Frame>

                                    <StackLayout Grid.Column="1"
                                                 Spacing="4"
                                                 VerticalOptions="Center">
                                        <Label Text="{Binding name}"
                                               FontAttributes="Bold"
                                               FontSize="15" TextColor="Black"/>
                                        <Label Text="{Binding formattedPrice}"
                                               TextColor="#2E7D32"
                                               FontSize="14"
                                               FontAttributes="Bold"/>
                                    </StackLayout>

                                    <StackLayout Grid.Column="2"
                                                 Spacing="8"
                                                 VerticalOptions="Center">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto"
                                              ColumnSpacing="4">
                                            <Button Grid.Column="0" Text="−"
                                                    BackgroundColor="#F5F5F0"
                                                    TextColor="Black"
                                                    CornerRadius="6"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    Padding="0"
                                                    Clicked="Decrease_Clicked"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding quantity}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="Black"
                                                   WidthRequest="36"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   HorizontalTextAlignment="Center"/>
                                            <Button Grid.Column="2" Text="+"
                                                    BackgroundColor="#F5F5F0"
                                                    TextColor="Black"
                                                    CornerRadius="6"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    Padding="0"
                                                    Clicked="Increase_Clicked"/>
                                        </Grid>
                                        <Button Text="Remove"
                                                BackgroundColor="#C62828"
                                                TextColor="White"
                                                CornerRadius="6"
                                                FontSize="12"
                                                Padding="8,4"
                                                Clicked="Remove_Clicked"/>
                                    </StackLayout>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </StackLayout>
        </ScrollView>

        <Frame Grid.Row="1"
               Padding="24,16"
               CornerRadius="0"
               HasShadow="True"
               BackgroundColor="White">
            <StackLayout HorizontalOptions="Center"
                         WidthRequest="600"
                         Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Subtotal" FontSize="13" TextColor="#666"/>
                    <Label x:Name="subtotalLabel" Grid.Column="1"
                           FontSize="13" TextColor="Black"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Delivery Fee" FontSize="13" TextColor="#666"/>
                    <Label x:Name="deliveryLabel" Grid.Column="1"
                           FontSize="13" TextColor="Black"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Tax" FontSize="13" TextColor="#666"/>
                    <Label x:Name="taxLabel" Grid.Column="1"
                           FontSize="13" TextColor="Black"/>
                </Grid>
                <BoxView HeightRequest="1" Color="#F0F0F0"/>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Total" FontSize="16"
                           FontAttributes="Bold" TextColor="Black"/>
                    <Label x:Name="totalLabel" Grid.Column="1"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="#2E7D32"/>
                </Grid>
                <Button Text="PROCEED TO CHECKOUT"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        CornerRadius="10"
                        FontSize="15"
                        FontAttributes="Bold"
                        Padding="0,16"
                        Margin="0,8,0,0"
                        Clicked="Checkout_Clicked"/>
            </StackLayout>
        </Frame>

    </Grid>
</ContentPage>