<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.PaymentMethodPage"
             Title="Payment Method"
             BackgroundColor="#F5F5F0">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <StackLayout HorizontalOptions="Center"
                         WidthRequest="500"
                         Padding="24" Spacing="16">

                <Label Text="Select Payment Method"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="Black" Margin="0,8,0,4"/>

               
                <Frame x:Name="FrameCreditCard"
                       BorderColor="#2E7D32"
                       CornerRadius="10"
                       Padding="16"
                       HasShadow="True"
                       BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPaymentSelected"
                                              CommandParameter="CreditCard"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="💳"
                               FontSize="22" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Credit / Debit Card"
                               FontSize="15" TextColor="Black"
                               VerticalOptions="Center" Margin="12,0,0,0"/>
                        <Ellipse x:Name="RadioCreditCard"
                                 Grid.Column="2"
                                 WidthRequest="20" HeightRequest="20"
                                 Stroke="#2E7D32" StrokeThickness="2"
                                 Fill="#2E7D32"
                                 VerticalOptions="Center"/>
                    </Grid>
                </Frame>

              
                <Frame Padding="16" CornerRadius="10"
                       HasShadow="False" BackgroundColor="White"
                       BorderColor="#E0E0E0">
                    <StackLayout Spacing="8">
                        <Label Text="CARD" FontSize="11"
                               FontAttributes="Bold" TextColor="#888"
                               CharacterSpacing="1.5"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="selectedCardLabel"
                                   Text="No card selected"
                                   FontSize="14" TextColor="Black"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="Choose Card"
                                    BackgroundColor="#2E7D32"
                                    TextColor="White"
                                    CornerRadius="8"
                                    FontSize="13"
                                    Padding="12,8"
                                    Clicked="OnChooseCardClicked"/>
                        </Grid>
                    </StackLayout>
                </Frame>

            </StackLayout>
        </ScrollView>

        <Button Grid.Row="1"
                Text="CONTINUE"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="10"
                FontSize="15"
                FontAttributes="Bold"
                Padding="0,16"
                Margin="24"
                Clicked="OnContinueClicked"/>

    </Grid>
</ContentPage>