<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.MapPage"
             Title="Nearby Farmers"
             BackgroundColor="#F5F5F0">

    <Grid RowDefinitions="*,Auto">

       
        <WebView x:Name="mapWebView"
                 Grid.Row="0"/>

        <StackLayout x:Name="loadingOverlay"
                     Grid.Row="0"
                     BackgroundColor="#88000000"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill"
                     IsVisible="True">
            <ActivityIndicator IsRunning="True" Color="White"
                               VerticalOptions="CenterAndExpand"/>
            <Label Text="Finding nearby farmers..."
                   TextColor="White"
                   HorizontalOptions="Center"
                   FontSize="14"/>
        </StackLayout>

       
        <Frame x:Name="farmerCard"
               Grid.Row="1"
               Padding="16"
               CornerRadius="16"
               HasShadow="True"
               BackgroundColor="White"
               IsVisible="False"
               Margin="12,0,12,12">
            <StackLayout Spacing="8">
                <Label x:Name="farmerNameLabel"
                       FontSize="16" FontAttributes="Bold" TextColor="#222"/>
                <Label x:Name="farmerAddressLabel"
                       FontSize="13" TextColor="#888"/>
                <Button Text="View Products"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnViewProductsClicked"/>
            </StackLayout>
        </Frame>

    </Grid>
</ContentPage>