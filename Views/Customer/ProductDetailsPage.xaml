<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.ProductDetailsPage"
             Title="ProductDetails">
    <ScrollView>

        <VerticalStackLayout
            Padding="10">

            <Image x:Name="productImage" Aspect="AspectFill" HeightRequest="200"/>

            <FlexLayout 
                Padding="5"
                JustifyContent="SpaceBetween"
                
                >

                <Label x:Name="productName" FontSize="24" FontAttributes="Bold"/>
                <Label x:Name="productPrice" FontSize="18" TextColor="Green"/>

            </FlexLayout>


            <Label x:Name="productDescription" FontSize="16"/>

            <HorizontalStackLayout>
                <Button Text="-" Clicked="Decrease_Clicked"/>
                <Label x:Name="quantityLabel" Text="1"/>
                <Button Text="+" Clicked="Increase_Clicked"/>
            </HorizontalStackLayout>


            <Button Text="Add to Cart" Clicked="AddToCart_Clicked"/>

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>
