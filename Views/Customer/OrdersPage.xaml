<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LeafBucket.Components"
             x:Class="LeafBucket.Views.Customer.OrdersPage"
             Title="My Orders"
             BackgroundColor="#F5F5F0">

    <RefreshView x:Name="refreshView" Refreshing="OnRefreshing">
        <ScrollView>
            <StackLayout Padding="8" Spacing="4">

            
                <StackLayout x:Name="emptyState" IsVisible="False"
                             HorizontalOptions="Center" Margin="0,80,0,0" Spacing="12">
                    <Label Text="🛍️" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No orders yet" FontSize="18" FontAttributes="Bold"
                           HorizontalOptions="Center" TextColor="#333"/>
                    <Label Text="Your past orders will appear here."
                           FontSize="14" TextColor="#888" HorizontalOptions="Center"/>
                </StackLayout>

                <StackLayout x:Name="ordersStack" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <components:OrderCard
                                Order="{Binding .}"
                                OrderId="{Binding ShortOrderId}"
                                Date="{Binding FormattedDate}"
                                Status="{Binding status}"
                                Summary="{Binding ItemSummary}"/>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>

            </StackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>