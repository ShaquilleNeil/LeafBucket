<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.OrderSummaryPage"
             Title="Order Summary"
             BackgroundColor="#F5F5F0">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <StackLayout HorizontalOptions="Center"
                         WidthRequest="500"
                         Padding="24" Spacing="16">

               
                <Label Text="SHIPPING ADDRESS" FontSize="11"
                       FontAttributes="Bold" TextColor="#888"
                       CharacterSpacing="1.5"/>
                <Frame BorderColor="#E0E0E0" CornerRadius="10"
                       Padding="16" HasShadow="False"
                       BackgroundColor="White">
                    <StackLayout Spacing="4">
                        <Label x:Name="Name" FontAttributes="Bold"
                               FontSize="15" TextColor="Black"/>
                        <Label x:Name="Address" FontSize="14"
                               TextColor="Black"/>
                    </StackLayout>
                </Frame>

               
                <Label Text="PAYMENT METHOD" FontSize="11"
                       FontAttributes="Bold" TextColor="#888"
                       CharacterSpacing="1.5"/>
                <Frame BorderColor="#E0E0E0" CornerRadius="10"
                       Padding="16" HasShadow="False"
                       BackgroundColor="White">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="paymentMethod" FontSize="14"
                               TextColor="Black" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Edit"
                               TextColor="#2E7D32" FontAttributes="Bold"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditPaymentTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Frame>

              
                <Label Text="ITEMS" FontSize="11"
                       FontAttributes="Bold" TextColor="#888"
                       CharacterSpacing="1.5"/>
                <Frame BorderColor="#E0E0E0" CornerRadius="10"
                       Padding="16" HasShadow="False"
                       BackgroundColor="White">
                    <StackLayout x:Name="itemsStack" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                    <StackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding name}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="Black"/>
                                        <Label Text="{Binding quantity, StringFormat='Qty: {0}'}"
                                               FontSize="12" TextColor="#888"/>
                                    </StackLayout>
                                    <Label Grid.Column="1" FontSize="14"
                                           TextColor="Black"
                                           VerticalOptions="Center">
                                        <Label.Text>
                                            <MultiBinding StringFormat="${0:F2}">
                                                <Binding Path="price"/>
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </Frame>

             
                <Frame BorderColor="#E0E0E0" CornerRadius="10"
                       Padding="16" HasShadow="False"
                       BackgroundColor="White">
                    <StackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Subtotal" FontSize="14" TextColor="#666"/>
                            <Label x:Name="subtotal" Grid.Column="1"
                                   FontSize="14" TextColor="Black"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Delivery Fee" FontSize="14" TextColor="#666"/>
                            <Label x:Name="deliveryFee" Grid.Column="1"
                                   FontSize="14" TextColor="Black"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Taxes (Estimated)" FontSize="14" TextColor="#666"/>
                            <Label x:Name="tax" Grid.Column="1"
                                   FontSize="14" TextColor="Black"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Grand Total" FontSize="16"
                                   FontAttributes="Bold" TextColor="Black"/>
                            <Label x:Name="grandTotal" Grid.Column="1"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#2E7D32"/>
                        </Grid>
                    </StackLayout>
                </Frame>

            </StackLayout>
        </ScrollView>

        <Button Grid.Row="1"
                Text="PLACE ORDER"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="10"
                FontSize="15"
                FontAttributes="Bold"
                Padding="0,16"
                Margin="24"
                Clicked="OnPlaceOrderClicked"/>

    </Grid>
</ContentPage>