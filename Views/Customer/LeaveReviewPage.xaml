<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.LeaveReviewPage"
             Title="Leave a Review"
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <StackLayout HorizontalOptions="Center"
                     WidthRequest="500"
                     Padding="24" Spacing="16">

           
            <Label x:Name="productNameLabel"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="Black" HorizontalOptions="Center"/>

            
            <Label Text="TAP TO RATE" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5"/>

            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                <Button Grid.Column="0" x:Name="star1" Text="★"
                        FontSize="32" BackgroundColor="Transparent"
                        TextColor="#E0E0E0" Padding="0"
                        Clicked="OnStarClicked" CommandParameter="1"/>
                <Button Grid.Column="1" x:Name="star2" Text="★"
                        FontSize="32" BackgroundColor="Transparent"
                        TextColor="#E0E0E0" Padding="0"
                        Clicked="OnStarClicked" CommandParameter="2"/>
                <Button Grid.Column="2" x:Name="star3" Text="★"
                        FontSize="32" BackgroundColor="Transparent"
                        TextColor="#E0E0E0" Padding="0"
                        Clicked="OnStarClicked" CommandParameter="3"/>
                <Button Grid.Column="3" x:Name="star4" Text="★"
                        FontSize="32" BackgroundColor="Transparent"
                        TextColor="#E0E0E0" Padding="0"
                        Clicked="OnStarClicked" CommandParameter="4"/>
                <Button Grid.Column="4" x:Name="star5" Text="★"
                        FontSize="32" BackgroundColor="Transparent"
                        TextColor="#E0E0E0" Padding="0"
                        Clicked="OnStarClicked" CommandParameter="5"/>
            </Grid>

          
            <Label Text="WRITE YOUR REVIEW" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5"/>
            <Frame Padding="12,8" CornerRadius="10"
                   HasShadow="False" BackgroundColor="White"
                   BorderColor="#E0E0E0">
                <Editor x:Name="commentEntry"
                        Placeholder="Enter your comments here..."
                        MinimumHeightRequest="120"
                        BackgroundColor="Transparent"
                        TextColor="Black"/>
            </Frame>

           
            <Button Text="SUBMIT REVIEW"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="15"
                    FontAttributes="Bold"
                    Padding="0,16"
                    Clicked="OnSubmitClicked"/>

        </StackLayout>
    </ScrollView>
</ContentPage>