<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Customer.OrderDetailsPage"
             Title="Order Details"
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <StackLayout HorizontalOptions="Center"
                     WidthRequest="600"
                     Padding="24" Spacing="16">

      
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <StackLayout Spacing="8">

                    <Label x:Name="orderIdLabel" FontSize="14"
                           TextColor="Black" FontAttributes="Bold"/>
                    <Label x:Name="orderDateLabel" FontSize="12"
                           TextColor="#888"/>

                    <Frame x:Name="statusBadge" Padding="12,6"
                           CornerRadius="20" HasShadow="False"
                           HorizontalOptions="Start">
                        <Label x:Name="statusLabel" FontSize="13"
                               FontAttributes="Bold" TextColor="White"/>
                    </Frame>

                    <Grid ColumnDefinitions="*,*,*,*" Margin="0,12,0,0">
                        <StackLayout Grid.Column="0" Spacing="4">
                            <BoxView x:Name="stepPlaced" HeightRequest="4" CornerRadius="2"/>
                            <Label Text="Placed" FontSize="10"
                                   HorizontalOptions="Center" TextColor="Black"/>
                        </StackLayout>
                        <StackLayout Grid.Column="1" Spacing="4">
                            <BoxView x:Name="stepPreparing" HeightRequest="4" CornerRadius="2"/>
                            <Label Text="Preparing" FontSize="10"
                                   HorizontalOptions="Center" TextColor="Black"/>
                        </StackLayout>
                        <StackLayout Grid.Column="2" Spacing="4">
                            <BoxView x:Name="stepShipped" HeightRequest="4" CornerRadius="2"/>
                            <Label Text="Shipped" FontSize="10"
                                   HorizontalOptions="Center" TextColor="Black"/>
                        </StackLayout>
                        <StackLayout Grid.Column="3" Spacing="4">
                            <BoxView x:Name="stepCompleted" HeightRequest="4" CornerRadius="2"/>
                            <Label Text="Delivered" FontSize="10"
                                   HorizontalOptions="Center" TextColor="Black"/>
                        </StackLayout>
                    </Grid>

                </StackLayout>
            </Frame>

          
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <StackLayout Spacing="12">
                    <Label Text="Items" FontSize="16"
                           FontAttributes="Bold" TextColor="Black"/>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <StackLayout x:Name="itemsStack" Spacing="8">
                   
                    </StackLayout>
                </StackLayout>
            </Frame>

           
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <StackLayout Spacing="10">
                    <Label Text="Delivery Info" FontSize="16"
                           FontAttributes="Bold" TextColor="Black"/>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="📍" FontSize="14"/>
                        <Label x:Name="addressLabel" Grid.Column="1"
                               FontSize="13" TextColor="Black"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="💳" FontSize="14"/>
                        <Label x:Name="paymentLabel" Grid.Column="1"
                               FontSize="13" TextColor="Black"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <StackLayout Spacing="10">
                    <Label Text="Summary" FontSize="16"
                           FontAttributes="Bold" TextColor="Black"/>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Subtotal" FontSize="13" TextColor="#666"/>
                        <Label x:Name="subtotalLabel" Grid.Column="1"
                               FontSize="13" TextColor="Black"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Delivery Fee" FontSize="13" TextColor="#666"/>
                        <Label x:Name="deliveryLabel" Grid.Column="1"
                               FontSize="13" TextColor="Black"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Tax (10%)" FontSize="13" TextColor="#666"/>
                        <Label x:Name="taxLabel" Grid.Column="1"
                               FontSize="13" TextColor="Black"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#F0F0F0"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total" FontSize="15"
                               FontAttributes="Bold" TextColor="Black"/>
                        <Label x:Name="totalLabel" Grid.Column="1"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="#2E7D32"/>
                    </Grid>
                </StackLayout>
            </Frame>

        </StackLayout>
    </ScrollView>
</ContentPage>