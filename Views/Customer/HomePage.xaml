<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:LeafBucket.Components"
             x:Class="LeafBucket.Views.Customer.HomePage"
             >


    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="cart.png"
            Clicked="openCart"
            
            />

    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
            <Border
               Grid.Row="0"
     Stroke="DarkSlateGray"
     StrokeThickness="2"
     StrokeShape="RoundRectangle 10"
     Padding="2"
     Margin="0,0,0,20"
               
     >
                <SearchBar Placeholder="Search Products..." TextChanged="SearchBar_TextChanged" />


            </Border>

            <CollectionView Grid.Row="1" x:Name="ProductsCollection" SelectionMode="Single" SelectionChanged="ProductSelected">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <components:ProductCard
         Name="{Binding name}"
         Category="{Binding category}"
         Price="{Binding formattedPrice}"
         Location="{Binding location}"
         ImageUrl="{Binding imageUrl}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

       


</ContentPage>
