<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Farmer.EditProductPage"
             Title="Edit Product"
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <StackLayout HorizontalOptions="Center"
                     WidthRequest="500"
                     Padding="24" Spacing="12">

            <Image x:Name="productImage" HeightRequest="200"
                   BackgroundColor="#E8F5E9" Aspect="AspectFill"/>

            <Button x:Name="pickImage_Button" Text="Replace Image"
                    BackgroundColor="#2E7D32" TextColor="White"
                    CornerRadius="8" Clicked="PickImage_Clicked"/>

            <Label Text="PRODUCT NAME" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="12,8" CornerRadius="8" HasShadow="False"
                   BackgroundColor="White" BorderColor="#E0E0E0">
                <Entry x:Name="nameEntry" BackgroundColor="Transparent"
                       TextColor="Black"/>
            </Frame>

            <Label Text="CATEGORY" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="4,0" CornerRadius="8" HasShadow="False"
                   BackgroundColor="White" BorderColor="#E0E0E0">
                <Picker x:Name="categoryPicker" Title="Select Category"
                        TextColor="Black">
                    <Picker.Items>
                        <x:String>Fresh Produce</x:String>
                        <x:String>Fruits</x:String>
                        <x:String>Vegetables</x:String>
                        <x:String>Dairy</x:String>
                        <x:String>Eggs</x:String>
                        <x:String>Meat</x:String>
                        <x:String>Honey &amp; Preserves</x:String>
                        <x:String>Herbs &amp; Spices</x:String>
                        <x:String>Other</x:String>
                    </Picker.Items>
                </Picker>
            </Frame>

            <Label Text="UNITS" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="4,0" CornerRadius="8" HasShadow="False"
                   BackgroundColor="White" BorderColor="#E0E0E0">
                <Picker x:Name="unitPicker" Title="Select unit"
                        TextColor="Black">
                    <Picker.Items>
                        <x:String>Kg</x:String>
                        <x:String>g</x:String>
                        <x:String>Lb</x:String>
                        <x:String>Oz</x:String>
                        <x:String>Each</x:String>
                        <x:String>Unit</x:String>
                        <x:String>Piece</x:String>
                        <x:String>Item</x:String>
                        <x:String>Bunch</x:String>
                        <x:String>Bundle</x:String>
                        <x:String>Pack</x:String>
                        <x:String>Bag</x:String>
                        <x:String>Basket</x:String>
                        <x:String>Box</x:String>
                        <x:String>Crate</x:String>
                        <x:String>Tray</x:String>
                        <x:String>Carton</x:String>
                        <x:String>Liter</x:String>
                        <x:String>Milliliter</x:String>
                        <x:String>Cup</x:String>
                        <x:String>Small</x:String>
                        <x:String>Medium</x:String>
                        <x:String>Large</x:String>
                        <x:String>Dozen</x:String>
                        <x:String>Half Dozen</x:String>
                        <x:String>Slice</x:String>
                        <x:String>Head</x:String>
                        <x:String>Clove</x:String>
                        <x:String>Family Pack</x:String>
                        <x:String>Weekly Box</x:String>
                        <x:String>Half Crate</x:String>
                        <x:String>Bulk</x:String>
                    </Picker.Items>
                </Picker>
            </Frame>

            <Label Text="PRICE" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="12,8" CornerRadius="8" HasShadow="False"
                   BackgroundColor="White" BorderColor="#E0E0E0">
                <Entry x:Name="priceEntry" Keyboard="Numeric"
                       BackgroundColor="Transparent" TextColor="Black"/>
            </Frame>

            <Label Text="QUANTITY" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="12,8" CornerRadius="8" HasShadow="False"
                   BackgroundColor="White" BorderColor="#E0E0E0">
                <Entry x:Name="stockEntry" Keyboard="Numeric"
                       BackgroundColor="Transparent" TextColor="Black"/>
            </Frame>

            <Label Text="DESCRIPTION" FontSize="11"
                   FontAttributes="Bold" TextColor="#888"
                   CharacterSpacing="1.5" Margin="0,8,0,0"/>
            <Frame Padding="12,8" CornerRadius="8" HasShadow="False"
                   BackgroundColor="White" BorderColor="#E0E0E0">
                <Editor x:Name="productDescription"
                        MinimumHeightRequest="100"
                        BackgroundColor="Transparent"
                        TextColor="Black"/>
            </Frame>

            <Button x:Name="saveProductButton"
                    Text="SAVE CHANGES"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="15"
                    FontAttributes="Bold"
                    Padding="0,16"
                    Margin="0,8,0,0"
                    Clicked="saveProduct"/>

        </StackLayout>
    </ScrollView>
</ContentPage>