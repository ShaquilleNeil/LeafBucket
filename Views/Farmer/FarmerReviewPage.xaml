<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Views.Farmer.FarmerReviewPage"
             Title=""
             BackgroundColor="#F5F5F0">

    <ScrollView>
        <StackLayout HorizontalOptions="Center"
                     WidthRequest="700"
                     Padding="24" Spacing="16">

            <Label Text="LEAF BUCKET" FontSize="22"
                   FontAttributes="Bold" TextColor="#2E7D32"/>
            <Label Text="Customer Reviews" FontSize="14"
                   TextColor="#888" Margin="0,-10,0,0"/>

            <StackLayout x:Name="emptyState" IsVisible="False"
                         HorizontalOptions="Center"
                         Margin="0,60,0,0" Spacing="12">
                <Label Text="⭐" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="No reviews yet" FontSize="18"
                       FontAttributes="Bold" TextColor="Black"
                       HorizontalOptions="Center"/>
                <Label Text="Reviews from customers will appear here."
                       FontSize="14" TextColor="#888"
                       HorizontalOptions="Center"/>
            </StackLayout>

           
            <StackLayout x:Name="reviewsStack" Spacing="12"/>

        </StackLayout>
    </ScrollView>
</ContentPage>