<?xml version="1.0" encoding="utf-8" ?>
<ContentView 
    x:Name="self"
    x:Class="LeafBucket.Components.ProductCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border StrokeShape="RoundRectangle 12"
            Stroke="#E0E0E0"
            BackgroundColor="White"
            Padding="0"
            Margin="4">
        <VerticalStackLayout Spacing="0">

            <Image Source="{Binding ImageUrl, Source={x:Reference self}}"
                   HeightRequest="140"
                   Aspect="AspectFill"/>

            <VerticalStackLayout Padding="10" Spacing="4">

                <Label Text="{Binding Category, Source={x:Reference self}}"
                       FontSize="11" TextColor="#888"/>

                <Label Text="{Binding Name, Source={x:Reference self}}"
                       FontAttributes="Bold"
                       FontSize="15" TextColor="Black"/>

                <Label Text="{Binding Location, Source={x:Reference self}}"
                       FontSize="11" TextColor="#888"/>

                <Label Text="{Binding Price, Source={x:Reference self}}"
                       FontSize="14" TextColor="#2E7D32"
                       FontAttributes="Bold"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>

</ContentView>