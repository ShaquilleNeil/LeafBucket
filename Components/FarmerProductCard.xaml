<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Components.FarmerProductCard"
             x:Name="self">

    <Border StrokeShape = "RoundRectangle 10" Padding="10" WidthRequest="190">
        <VerticalStackLayout>
            
            <Image
             Source = "{Binding ImageUrl, Source={x:Reference self}}"
             HeightRequest="120"
             Aspect="AspectFill"/>

            <Label
             Text = "{Binding Category, Source={x:Reference self}}"
             FontSize="12"
             TextColor="Gray"/>

            <Label
             Text = "{Binding Name, Source={x:Reference self}}"
             FontAttributes="Bold"
             FontSize="16"/>


            <Label
             Text = "{Binding Price, Source={x:Reference self}}"
             FontSize="14"
             TextColor="Green"
             FontAttributes="Bold"/>

            <Label
              Text = "{Binding StockQuantity, Source={x:Reference self}}"
              FontSize="14"
              TextColor="Green"
              FontAttributes="Bold"/>


            <Button
             Text = "Update"
             BackgroundColor="Blue"
             TextColor="White"
             Clicked="updateProduct"
             CornerRadius="8"/>

            <Button
              Text = "Delete"
              BackgroundColor="Red"
              TextColor="White"
              CornerRadius="8"
                Clicked="deleteProduct"/>
        </VerticalStackLayout>
    </Border>
</ContentView>
