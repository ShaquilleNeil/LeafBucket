<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Components.FarmerProductCard"
             x:Name="self">

    <Border StrokeShape="RoundRectangle 12"
            Stroke="#E0E0E0"
            BackgroundColor="White"
            Padding="0"
            Margin="4">
        <VerticalStackLayout Spacing="0">

            <Image Source="{Binding ImageUrl, Source={x:Reference self}}"
                   HeightRequest="140"
                   Aspect="AspectFill"/>

            <VerticalStackLayout Padding="10" Spacing="4">

                <Label Text="{Binding Category, Source={x:Reference self}}"
                       FontSize="11" TextColor="#888"/>

                <Label Text="{Binding Name, Source={x:Reference self}}"
                       FontAttributes="Bold"
                       FontSize="15" TextColor="Black"/>

                <Label Text="{Binding Price, Source={x:Reference self}}"
                       FontSize="14" TextColor="#2E7D32"
                       FontAttributes="Bold"/>

                <Label Text="{Binding StockQuantity, Source={x:Reference self}}"
                       FontSize="12" TextColor="#888"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="Edit"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            CornerRadius="8"
                            FontSize="13"
                            Clicked="updateProduct"/>
                    <Button Grid.Column="1" Text="Delete"
                            BackgroundColor="#C62828"
                            TextColor="White"
                            CornerRadius="8"
                            FontSize="13"
                            Clicked="deleteProduct"/>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>