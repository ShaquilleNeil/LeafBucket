<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Components.OrderCard"
             x:Name="Root">

    <Frame Padding="16" Margin="0,4"
           CornerRadius="12" HasShadow="True"
           BackgroundColor="White">

        <Frame.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped"/>
        </Frame.GestureRecognizers>

        <VerticalStackLayout Spacing="8">

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">

                <Label Text="{Binding OrderId, Source={x:Reference Root}}"
                       FontAttributes="Bold" FontSize="15"
                       TextColor="Black"/>

                <Label Text="{Binding Date, Source={x:Reference Root}}"
                       FontSize="12" TextColor="#888"
                       Grid.Column="0" Grid.Row="1"/>

                <Label Text="{Binding Status, Source={x:Reference Root}}"
                       TextColor="White" BackgroundColor="#888"
                       Padding="10,4" FontSize="12"
                       Grid.Column="1" Grid.RowSpan="2"
                       VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Preparing">
                            <Setter Property="BackgroundColor" Value="#E65100"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Processing">
                            <Setter Property="BackgroundColor" Value="#1565C0"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Shipped">
                            <Setter Property="BackgroundColor" Value="#2E7D32"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Cancelled">
                            <Setter Property="BackgroundColor" Value="#C62828"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

            </Grid>

            <Label Text="{Binding Summary, Source={x:Reference Root}}"
                   FontSize="13" TextColor="#666"/>

        </VerticalStackLayout>
    </Frame>
</ContentView>