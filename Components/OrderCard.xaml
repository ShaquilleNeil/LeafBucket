<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Components.OrderCard"
             x:Name="Root">

    <Frame 
        Padding="12"
        Margin="10"
        CornerRadius="12"
        HasShadow="True"
        BackgroundColor="White">

        <Frame.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped"/>
        </Frame.GestureRecognizers>


        <VerticalStackLayout Spacing="8">

          
            <Grid Padding="10" ColumnDefinitions="*,Auto" RowDefinitions="*, Auto">

                <Label 
                    Text="{Binding OrderId, Source={x:Reference Root}}"
                    FontAttributes="Bold"
                    FontSize="16"
                    />
                <Label 
                      Text="{Binding Date, Source={x:Reference Root}}"
                      FontSize="12"
                      TextColor="Gray"
                    Grid.Column="0"
                    Grid.Row="1"/>

                <Label 
                    Text="{Binding Status, Source={x:Reference Root}}"
                    TextColor="White"
                    BackgroundColor="Gray"
                    Padding="8,3"
                    FontSize="12"
                    Grid.Column="1"
                   >

                    <Label.Triggers>

                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Preparing">
                            <Setter Property="BackgroundColor" Value="Orange"/>
                        </DataTrigger>

                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Processing">
                            <Setter Property="BackgroundColor" Value="Blue"/>
                        </DataTrigger>

                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Shipped">
                            <Setter Property="BackgroundColor" Value="Green"/>
                        </DataTrigger>

                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Cancelled">
                            <Setter Property="BackgroundColor" Value="Red"/>
                        </DataTrigger>

                    </Label.Triggers>

                </Label>

            </Grid>

        
            <Label 
                Text="{Binding Summary, Source={x:Reference Root}}"
                FontSize="13"
                TextColor="Gray"
                Padding="10,0,0,0"/>

     

        </VerticalStackLayout>
    </Frame>
</ContentView>