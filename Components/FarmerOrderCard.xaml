<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeafBucket.Components.FarmerOrderCard"
             x:Name="Root">

    <Frame Padding="16" Margin="0,4" CornerRadius="12"
           HasShadow="True" BackgroundColor="White">

        <Frame.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCardTapped"/>
        </Frame.GestureRecognizers>

        <StackLayout Spacing="10">

           
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding OrderId, Source={x:Reference Root}}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#222" VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="{Binding Status, Source={x:Reference Root}}"
                       TextColor="White" Padding="10,4"
                       FontSize="11" FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Placed">
                            <Setter Property="BackgroundColor" Value="#1565C0"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Preparing">
                            <Setter Property="BackgroundColor" Value="#E65100"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Ready">
                            <Setter Property="BackgroundColor" Value="#558B2F"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Completed">
                            <Setter Property="BackgroundColor" Value="#757575"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding Status, Source={x:Reference Root}}"
                                     Value="Cancelled">
                            <Setter Property="BackgroundColor" Value="#C62828"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Grid>

           
            <Label Text="{Binding Date, Source={x:Reference Root}}"
                   FontSize="12" TextColor="#AAA"/>

           
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding Summary, Source={x:Reference Root}}"
                       FontSize="13" TextColor="#666"
                       VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="{Binding Total, Source={x:Reference Root}}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#2E7D32" VerticalOptions="Center"/>
            </Grid>

            <BoxView HeightRequest="1" Color="#F0F0F0"/>

          
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="False">
                <Grid.Triggers>
                    <DataTrigger TargetType="Grid"
                                 Binding="{Binding Status, Source={x:Reference Root}}"
                                 Value="Placed">
                        <Setter Property="IsVisible" Value="True"/>
                    </DataTrigger>
                </Grid.Triggers>
                <Button Grid.Column="0" Text="DECLINE"
                        BackgroundColor="White" TextColor="#C62828"
                        BorderColor="#C62828" BorderWidth="1"
                        CornerRadius="8" FontSize="13" FontAttributes="Bold"
                        Clicked="OnDeclineClicked"/>
                <Button Grid.Column="1" Text="ACCEPT"
                        BackgroundColor="#2E7D32" TextColor="White"
                        CornerRadius="8" FontSize="13" FontAttributes="Bold"
                        Clicked="OnAcceptClicked"/>
            </Grid>

           
            <Button Text="MARK AS READY"
                    BackgroundColor="#E65100" TextColor="White"
                    CornerRadius="8" FontSize="13" FontAttributes="Bold"
                    IsVisible="False" Clicked="OnMarkReadyClicked">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Status, Source={x:Reference Root}}"
                                 Value="Preparing">
                        <Setter Property="IsVisible" Value="True"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        
            <Button Text="MARK AS COMPLETED"
                    BackgroundColor="#558B2F" TextColor="White"
                    CornerRadius="8" FontSize="13" FontAttributes="Bold"
                    IsVisible="False" Clicked="OnMarkCompletedClicked">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Status, Source={x:Reference Root}}"
                                 Value="Ready">
                        <Setter Property="IsVisible" Value="True"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        </StackLayout>
    </Frame>
</ContentView>